# Copy to .env.local and fill in. Vite reads .env.local during dev.

# Base URL of the deployed content-tracking API (no trailing slash).
# Example: https://api.tracking.readysetcloud.io or the autogenerated
# execute-api hostname from the CloudFormation outputs.
VITE_API_BASE_URL=

# Cognito OIDC issuer URL — the User Pool issuer, NOT the Hosted UI domain.
# Format: https://cognito-idp.<region>.amazonaws.com/<userPoolId>
VITE_COGNITO_AUTHORITY=

# Hosted UI domain (no scheme, no trailing slash). Required for the
# sign-out redirect; the library uses this to build the /logout URL.
# Example: rsc-core-auth.auth.us-east-1.amazoncognito.com
VITE_COGNITO_HOSTED_UI_DOMAIN=

# App Client ID for this dashboard. Must have:
# - Allowed callback URL = VITE_COGNITO_REDIRECT_URI
# - Allowed sign-out URL = VITE_COGNITO_POST_LOGOUT_URI
# - Authorization code grant + openid scope enabled
VITE_COGNITO_CLIENT_ID=

# Where Cognito redirects after sign-in. For local dev, the Vite default
# is http://localhost:5173/auth/callback. Match this in the App Client.
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback

# Where Cognito redirects after sign-out.
VITE_COGNITO_POST_LOGOUT_URI=http://localhost:5173/
