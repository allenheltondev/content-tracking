# Copy to .env.local and fill in. Vite reads .env.local during dev.

# Base URL of the deployed content-tracking API (no trailing slash).
# Example: https://api.tracking.readysetcloud.io or the autogenerated
# execute-api hostname from the CloudFormation outputs.
VITE_API_BASE_URL=

# AWS region the Cognito user pool lives in.
VITE_AWS_REGION=us-east-1

# Cognito User Pool id. Same RSCUserPool that newsletter-service signs
# users into.
VITE_USER_POOL_ID=

# App Client id for this dashboard. Must have:
# - Authentication flow: USER_PASSWORD_AUTH (or ALLOW_USER_SRP_AUTH)
# - No client secret (public client)
# Matches the same shape newsletter-service uses; the dashboard signs
# users in inline rather than redirecting to the Cognito Hosted UI.
VITE_USER_POOL_CLIENT_ID=
