# Copy to .env.local and fill in. Vite reads .env.local during dev.

# Base URL of the deployed Booked API (no trailing slash).
# Example: https://api.booked.readysetcloud.io or the autogenerated
# execute-api hostname from the CloudFormation outputs.
VITE_API_BASE_URL=

# AWS region the shared Cognito user pool lives in.
VITE_AWS_REGION=us-east-1

# App client id for this dashboard — Booked's own public client on the
# shared RSCUserPool. Surfaced as the CloudFormation `UserPoolClientId`
# output (from template.yaml's UserPoolClient resource); the deploy
# workflow injects it automatically. @readysetcloud/ui/auth only needs
# the region + this client id, so the pool id is no longer required here.
VITE_USER_POOL_CLIENT_ID=

# Optional: Lambda Function URL for streaming compose/ask (StreamGenerateUrl
# from the CloudFormation outputs). When set, Compose and Ask render the
# generation live, token-by-token; when unset they fall back to the buffered
# REST endpoints.
VITE_STREAM_BASE_URL=

# Base URL of the shared rsc-core Core API (no trailing slash). Sourced from
# the rsc-core SSM parameter /readysetcloud/api-url (prod:
# https://api.readysetcloud.io/core). Backs the "Ask your blog" chat widget,
# which creates an agent session (POST /agent/sessions) and presigns a wss://
# connection to the shared AgentCore runtime (POST /agent/connect) using the
# shared Cognito id token. When unset, the widget is hidden.
VITE_CORE_API_URL=
