{
  "manifest_version": 3,
  "name": "Booked",
  "version": "0.1.0",
  "description": "Your Booked creator companion: quietly syncs engagement on your tracked posts, and grows your Content Radar from the sites you read.",
  "permissions": ["storage", "alarms", "activeTab", "scripting", "tabGroups"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.linkedin.com/*",
    "https://www.instagram.com/*",
    "https://bsky.app/*",
    "https://medium.com/*",
    "https://*.medium.com/*",
    "https://dev.to/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Booked"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://www.instagram.com/*",
        "https://bsky.app/*",
        "https://medium.com/*",
        "https://*.medium.com/*",
        "https://dev.to/*"
      ],
      "js": ["src/content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://www.instagram.com/*",
        "https://bsky.app/*",
        "https://medium.com/*",
        "https://*.medium.com/*",
        "https://dev.to/*"
      ],
      "js": ["src/content/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://bsky.app/*",
        "https://medium.com/*",
        "https://*.medium.com/*",
        "https://dev.to/*"
      ],
      "js": ["src/content/taskbar.js"],
      "run_at": "document_idle",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": ["https://www.linkedin.com/analytics/post-summary/*"],
      "js": ["src/content/analytics-linkedin.js"],
      "run_at": "document_idle",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": ["https://www.linkedin.com/posts/*"],
      "js": ["src/content/posts-linkedin.js"],
      "run_at": "document_idle",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": ["https://booked.readysetcloud.io/*"],
      "js": ["src/content/dashboard.js"],
      "run_at": "document_idle",
      "world": "ISOLATED",
      "all_frames": false
    }
  ]
}
