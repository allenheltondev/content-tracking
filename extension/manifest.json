{
  "manifest_version": 3,
  "name": "Booked Social Analytics",
  "version": "0.1.0",
  "description": "Automatically captures engagement on your tracked social posts and syncs it to the Booked app.",
  "permissions": ["identity", "storage", "alarms"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.linkedin.com/*",
    "https://www.instagram.com/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Booked Social Analytics"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["src/content/inject.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*",
        "https://www.instagram.com/*"
      ],
      "js": ["src/content/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.linkedin.com/*"
      ],
      "js": ["src/content/taskbar.js"],
      "run_at": "document_idle",
      "world": "ISOLATED",
      "all_frames": false
    }
  ]
}
